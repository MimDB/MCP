{
  "name": "@mimdb/mcp",
  "version": "0.1.0",
  "description": "MCP server for MimDB - AI assistant integration",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mimdb-mcp": "./bin/mimdb-mcp.ts"
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "minisearch": "^7.1.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "license": "MIT",
  "keywords": ["mimdb", "mcp", "model-context-protocol", "ai", "baas"],
  "engines": {
    "node": ">=20"
  }
}
